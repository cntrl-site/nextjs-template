{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "@cntrl-site/sdk-nextjs": ["../sdk-nextjs/src"],
      "@cntrl-site/sdk": ["../sdk/src"],
      "@cntrl-site/sdk/lib/*": ["../sdk/src/*"],
      "@cntrl-site/components/utils": ["../components/dist/Components/utils/index.d.ts"],
      "@cntrl-site/components": ["../components/dist/index.d.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
