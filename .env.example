CNTRL_API_URL=

# Optional override for the canonical site origin (e.g. https://example.com).
# Used by both the sitemap/robots generator AND the <link rel="canonical">
# + <meta og:url> tags emitted by the SDK. If unset, the project's primary
# domain returned by the API is used. Only set this to override.
SITE_URL=

# Local development (relative paths from this project root)
LOCAL_SDK_NEXTJS_REL_PATH=
LOCAL_SDK_REL_PATH=
LOCAL_COMPONENTS_REL_PATH=
